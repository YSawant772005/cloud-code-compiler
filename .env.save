# RDS PostgreSQL Connection
DATABASE_URL=postgresql://adminuser:YOURPASSWORD@YOUR_RDS_ENDPOINT:5432/codecompilerdb

# ElastiCache Redis Connection
REDIS_URL=redis://YOUR_REDIS_ENDPOINT:6379/0

# S3 Bucket
S3_BUCKET=code-compiler-logs-yourname

# JWT Secret (make this a long random string)
JWT_SECRET=your-super-secret-jwt-key-make-this-very-long-and-random

# AWS Region
AWS_REGION=ap-south-1

# Flask Config
FLASK_ENV=production
